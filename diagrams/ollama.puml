@startuml
autonumber

actor Player
participant Command
participant ManagerService
participant ConversationService
participant OllamaService
participant OllamaClient
participant HttpClient



Player -> Command: "/genius <prompt>"
Command -> ManagerService: generateChat(uuid, prompt)
ManagerService -> ConversationService: getMessagesForPlayer(uuid)
ConversationService -->> ManagerService: context messages
ManagerService -> OllamaService: context messages + player message
OllamaService -> OllamaClient: fetchResponse(ollama request)
OllamaClient -> HttpClient: sendAsync(http request)

HttpClient -->> OllamaClient: http response
OllamaClient -->> OllamaService: ollama response
OllamaService -->> ManagerService: ollama message
ManagerService -->> Command: response
Command -> Player: "[Genius] <response>"

@enduml